# Copy to .env.local and fill in values (Phase 0 — ARCHITECTURE.md).
# Supabase: Settings → API (URL + anon + service_role).
# R2: Cloudflare dashboard → R2 → API tokens + bucket name + public URL (custom domain).
# Resend: API Keys after domain verification.

# Created by Vercel CLI
VERCEL_OIDC_TOKEN=...your vercel token...

# Supabase
SUPABASE_URL=...create your supabase...
SUPABASE_SERVICE_ROLE_KEY=...key with previledged management...
SUPABASE_PUBLISHABLE_KEY=...key used to publish...
NEXT_PUBLIC_SUPABASE_URL=database
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=...

# Cloudflare R2
R2_ACCOUNT_ID=...
R2_ACCOUNT_ENDPOINT=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=public-photos
R2_PUBLIC_URL=https://media.your-domain.com

# Resend
RESEND_API_KEY=...
RESEND_FROM_EMAIL="Your Name <noreply@your-domain.com>"
RESEND_WEBHOOK_PUBLIC_URL=https://your.domain/api/webhooks/resend/inbound
RESEND_INBOUND_DOMAIN=your.domain

# Admin
ADMIN_EMAIL=your-personal-mail@server.com
ADMIN_SECRET=...

# Payment details
PAYMENTS_VENMO_USERNAME=
PAYMENTS_CASHAPP_TAG=
PAYMENTS_PAYPAL_ID=
PAYMENTS_ZELLE_PHONE=

NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Admin credentials for website
ADMIN_SESSION_SECRET=...
# Optional rate limits (defaults in @features/admin-api README)
ADMIN_RATE_LIMIT_LOGIN_MAX=10
ADMIN_RATE_LIMIT_LOGIN_WINDOW_SEC=900
ADMIN_RATE_LIMIT_API_MAX=300
ADMIN_RATE_LIMIT_API_WINDOW_SEC=60